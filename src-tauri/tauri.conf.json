{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Agent Arcade",
  "version": "0.3.1",
  "identifier": "com.danwahlin.agentarcade",
  "build": {
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "game/index.html",
        "title": "Agent Arcade",
        "width": 1920,
        "height": 1080,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; media-src 'self' asset: https://asset.localhost data: blob:; connect-src 'self' asset: https://asset.localhost blob: ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/tray_icon.png",
      "iconAsTemplate": false,
      "tooltip": "Agent Arcade"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Game",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzREEwMDI4QUNGQTAzNjUKUldSbEEvcXNLQURhTXdISjBsU3VNTXkwd29sWGg2Qmx5VHdiOEhvbnlOd2NxTHoxMCtSSHQ4OUsK",
      "endpoints": [
        "https://github.com/DanWahlin/agent-arcade/releases/latest/download/latest.json"
      ]
    }
  }
}
