{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Agent Arcade",
  "version": "0.1.0",
  "identifier": "com.danwahlin.agentarcade",
  "build": {
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "game/index.html",
        "title": "Agent Arcade",
        "width": 1920,
        "height": 1080,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "fullscreen": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' data: blob:; connect-src 'self' blob: ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/tray_icon.png",
      "iconAsTemplate": true,
      "tooltip": "Agent Arcade"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "targets": "all",
    "category": "Game",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {}
}
